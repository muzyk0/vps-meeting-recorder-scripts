# Copy to .env and adjust as needed.

# Common
DISPLAY=:99
SESSION_NAME=telemost-recorder
GUEST_NAME=Гость
LOG_DIR=./logs
ARTIFACTS_DIR=./artifacts
OUTPUT_DIR=~/Movies/Records
DRY_RUN=0

# Xvfb / PulseAudio
SCREEN_SIZE=1280x720x24
SCREEN_GEOMETRY=1280x720
XDG_RUNTIME_DIR=/tmp/xdg-runtime-admin
PULSE_SINK_NAME=meeting_sink
PULSE_SINK_DESCRIPTION=MeetingRecorderSink
FORCE_RESTART_AUDIO=0
FORCE_RESTART_XVFB=0

# Telemost join flow
MEETING_URL=
HEADED=1
NO_JOIN=1
JOIN_WAIT_MS=2000
PAGE_LOAD_WAIT_MS=6000
SCREENSHOT_DIR=./artifacts/screenshots/telemost-recorder
BROWSER_TRACE_DIR=./artifacts/browser/telemost-recorder
SAVE_HTML_DUMP=1

# Recording
DURATION=03:30:00
START_RECORDING_DELAY=8
AUDIO_WARMUP_DURATION=3
SIZE=1280x720
FPS=25
VIDEO_CODEC=libx264
VIDEO_PRESET=veryfast
VIDEO_BITRATE=2500k
MAXRATE=3000k
BUFSIZE=6000k
AUDIO_CODEC=aac
AUDIO_BITRATE=128k
AUDIO_CHANNELS=2
AUDIO_RATE=44100
FFMPEG_LOGLEVEL=warning
